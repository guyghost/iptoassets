{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "svelteSortOrder": "options-scripts-markup-styles",
        "parser": "svelte"
      }
    }
  ]
}
