DATABASE_URL=postgresql://ipms:ipms@localhost:5432/ipms

# Auth (OAuth providers)
AUTH_SECRET=your-auth-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_ISSUER=

# Email (Resend) — optional, no-op if absent
RESEND_API_KEY=
RESEND_FROM_ADDRESS=notifications@yourdomain.com

# Cron — required for POST /api/cron/check-deadlines
CRON_SECRET=
